# AWX/Ansible Tower connection (required)
ANSIBLE_BASE_URL=https://awx.example.com/
ANSIBLE_TOKEN=your_api_token

# Authentication alternative: username/password (instead of token)
# ANSIBLE_USERNAME=admin
# ANSIBLE_PASSWORD=secret

# --- TLS: outbound (this server -> AWX) ---

# SSL verification (default: true). Set to "false" only for dev/self-signed
# setups without a CA bundle — the server logs a warning when disabled.
ANSIBLE_SSL_VERIFY=true

# Path to a custom CA bundle / self-signed certificate (PEM) to trust when
# verification is enabled. Lets you connect to an AWX instance with a private
# CA without disabling verification.
# ANSIBLE_CA_BUNDLE=/path/to/ca-bundle.pem

# HTTP timeout for AWX API read operations in seconds (default: 90)
# AWX_HTTP_TIMEOUT_READ=90

# --- Transport / network ---

# MCP transport: stdio (default), sse, or streamable-http
# AWX_MCP_TRANSPORT=stdio

# Bind host/port for the sse and streamable-http transports
# AWX_MCP_HOST=127.0.0.1
# AWX_MCP_PORT=8000

# --- TLS: inbound (MCP client -> this server), sse/streamable-http only ---

# Serve HTTPS in-process (uvicorn) instead of plain HTTP. Ignored for stdio.
# AWX_MCP_TLS_ENABLE=true
# AWX_MCP_TLS_CERT=/path/to/server.crt
# AWX_MCP_TLS_KEY=/path/to/server.key
# AWX_MCP_TLS_KEY_PASSWORD=key_password_if_encrypted

# --- Access control ---

# When true, all write/destructive tools are unregistered at startup; only
# read-only tools (list_*/get_*) are exposed.
# AWX_MCP_READ_ONLY=true

# Opt-in: enable 4 credential/user write tools that collect sensitive data
# via Form-mode elicitation. See SECURITY.md for the threat model.
# AWX_MCP_ENABLE_CREDENTIAL_MANAGEMENT=true

# --- Logging / observability ---

# Path to a JSON Lines usage log; one JSON document per MCP tool call.
# Unset (default) disables instrumentation entirely.
# AWX_MCP_USAGE_LOG_FILE=/var/log/awx-mcp/usage.jsonl

# Path to a server diagnostic log file, mirroring the existing stderr output.
# Unset (default) means stderr only, no file.
# AWX_MCP_SERVER_LOG_FILE=/var/log/awx-mcp/server.log

# Server diagnostic log format: plain (default) or json
# AWX_MCP_SERVER_LOG_FORMAT=plain

# Number of rotated log files to retain (default: 7). Both log files rotate
# daily at midnight (UTC) with a date suffix.
# AWX_MCP_LOG_BACKUP_COUNT=7
