# =============================================================================
# Running modes are chosen by CLI flags, not env vars:
#   awx-mcp                       local stdio server (this file's settings)
#   awx-mcp --remote <URL>        client proxy to a central server (see below)
#   awx-mcp --serve [--sse]       central multi-user server (passthrough auth)
# =============================================================================

# --- Local mode (awx-mcp, no flags) -----------------------------------------

# AWX/Ansible Tower connection (required in local + --serve modes)
ANSIBLE_BASE_URL=https://awx.example.com/
ANSIBLE_TOKEN=your_api_token

# Authentication alternative: username/password (local mode only; the proxy
# forwards a Bearer token and cannot use username/password)
# ANSIBLE_USERNAME=admin
# ANSIBLE_PASSWORD=secret

# --- Proxy mode (awx-mcp --remote <URL>) ------------------------------------

# Central server URL. The --remote flag takes precedence over this env var.
# ANSIBLE_BASE_URL is NOT needed in proxy mode (the central server reaches AWX).
# Set ANSIBLE_TOKEN to your own AWX personal access token; the proxy forwards it
# as 'Authorization: Bearer <token>'. ANSIBLE_SSL_VERIFY / ANSIBLE_CA_BUNDLE
# below then verify the connection to the central server (not to AWX).
# AWX_MCP_REMOTE_URL=https://awx-mcp.example.com:8443/mcp

# Optional label recorded as the "user" field in the proxy's local usage log
# (proxy mode has no AWX access to resolve a username).
# AWX_MCP_USAGE_USER=your.name

# --- TLS: outbound (this server -> AWX) ---

# SSL verification (default: true). Set to "false" only for dev/self-signed
# setups without a CA bundle — the server logs a warning when disabled.
ANSIBLE_SSL_VERIFY=true

# Path to a custom CA bundle / self-signed certificate (PEM) to trust when
# verification is enabled. Lets you connect to an AWX instance with a private
# CA without disabling verification.
# ANSIBLE_CA_BUNDLE=/path/to/ca-bundle.pem

# HTTP timeout for AWX API read operations in seconds (default: 90)
# AWX_HTTP_TIMEOUT_READ=90

# --- Central server mode (awx-mcp --serve) ----------------------------------

# Bind host/port for --serve. The transport is streamable-http by default, or
# sse with `awx-mcp --serve --sse`. (There is no AWX_MCP_TRANSPORT env var; it
# was removed — use the flags.) Host/port may also be given as CLI flags.
# AWX_MCP_HOST=127.0.0.1
# AWX_MCP_PORT=8000

# In --serve mode the server holds NO AWX credentials: each request must carry
# the caller's own token as 'Authorization: Bearer <token>' (or X-AWX-Token),
# and AWX access is attributed to that caller in the usage log.

# --- TLS: inbound (MCP client -> this server), --serve only -----------------

# Serve HTTPS in-process (uvicorn) instead of plain HTTP. Strongly recommended
# for --serve, since caller tokens travel in a request header.
# AWX_MCP_TLS_ENABLE=true
# AWX_MCP_TLS_CERT=/path/to/server.crt
# AWX_MCP_TLS_KEY=/path/to/server.key
# AWX_MCP_TLS_KEY_PASSWORD=key_password_if_encrypted

# --- Access control ---

# Read-only mode. Semantics depend on where it is set:
#   * On the --serve central server: write/destructive tools are unregistered
#     globally; users CANNOT re-enable writes.
#   * In proxy mode (per user): the proxy sends 'X-AWX-Read-Only: true' and the
#     server rejects that caller's write-tool calls only. Advisory self-limit
#     (tighten-only); it is not a security boundary — the caller's AWX token
#     scope and server-global read-only are.
# AWX_MCP_READ_ONLY=true

# Opt-in: enable 4 credential/user write tools that collect sensitive data
# via Form-mode elicitation. See SECURITY.md for the threat model.
# AWX_MCP_ENABLE_CREDENTIAL_MANAGEMENT=true

# --- Logging / observability ---

# Path to a JSON Lines usage log; one JSON document per MCP tool call.
# Unset (default) disables instrumentation entirely.
# AWX_MCP_USAGE_LOG_FILE=/var/log/awx-mcp/usage.jsonl

# Path to a JSON Lines HTTP access log for the --serve network server; one
# JSON document per inbound request (client_ip, method, path, status,
# latency_ms, user_agent, has_auth). Unset (default) disables it. Not
# applicable to stdio / --remote (no HTTP server).
# AWX_MCP_ACCESS_LOG_FILE=/var/log/awx-mcp/access.jsonl

# Path to a server diagnostic log file, mirroring the existing stderr output.
# Unset (default) means stderr only, no file.
# AWX_MCP_SERVER_LOG_FILE=/var/log/awx-mcp/server.log

# Server diagnostic log format: plain (default) or json
# AWX_MCP_SERVER_LOG_FORMAT=plain

# Number of rotated log files to retain (default: 7). Both log files rotate
# daily at midnight (UTC) with a date suffix.
# AWX_MCP_LOG_BACKUP_COUNT=7
